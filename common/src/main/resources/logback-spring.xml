<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console appender: human-readable for local/dev -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%xwEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- JSON appender: machine-parseable for Fluent-bit / ELK, activated when ENV_STATE=prod -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <customFields>{"cluster":"leafy-cluster","environment":"${ENV_STATE:-dev}"}</customFields>
            <timeZone>UTC</timeZone>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
        <charset>UTF-8</charset>
    </appender>

    <!-- File appender: rolling file log on disk (always structured) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE:-logs/${springAppName:-spring}.log}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE:-logs/${springAppName:-spring}}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE:-10MB}</maxFileSize>
            <maxHistory>${LOG_FILE_MAX_HISTORY:-30}</maxHistory>
            <totalSizeCap>${LOG_FILE_TOTAL_SIZE_CAP:-1GB}</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timeZone>UTC</timeZone>
            <customFields>{"cluster":"leafy-cluster","environment":"${ENV_STATE:-dev}"}</customFields>
        </encoder>
    </appender>

    <!-- Conditional: prod ENV_STATE (set in ConfigMap on EKS) — JSON to stdout for Fluent-bit -->
    <if condition='property("ENV_STATE").equals("prod")'>
        <then>
            <root level="INFO">
                <appender-ref ref="JSON"/>
                <appender-ref ref="FILE"/>
            </root>
            <logger name="com.leafy" level="DEBUG" additivity="false">
                <appender-ref ref="JSON"/>
                <appender-ref ref="FILE"/>
            </logger>
        </then>
        <else>
            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
            </root>
            <logger name="com.leafy" level="DEBUG" additivity="false">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
            </logger>
        </else>
    </if>
</configuration>
