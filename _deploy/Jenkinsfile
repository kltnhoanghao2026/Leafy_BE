// Jenkinsfile for Multi-Branch Pipeline with GitHub Webhook
// This file should be placed in the repository root

@Library('pipeline-library') _

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
        disableConcurrentBuilds()
        timestamps()
    }

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'GIT_BRANCH', value: '$.ref', regexFilter: 'refs/heads/(.*)', defaultValue: 'unknown'],
                [key: 'GIT_REPO_URL', value: '$.repository.clone_url', defaultValue: ''],
                [key: 'GIT_COMMIT_SHA', value: '$.after', defaultValue: ''],
                [key: 'EVENT_TYPE', value: '$.action', defaultValue: 'push'],
                [key: 'PULL_REQUEST_NUMBER', value: '$.number', defaultValue: '']
            ],
            causeString: 'Triggered by GitHub webhook',
            regexpFilterText: '$GIT_BRANCH',
            regexpFilterExpression: '^(main|develop|release/.*|feature/.*|hotfix/.*)$'
        )
    }

    stages {
        stage('Detect Service Changed') {
            steps {
                script {
                    def changedServices = detectChangedServices()
                    if (changedServices.isEmpty()) {
                        echo "No service files changed, skipping build"
                        currentBuild.result = 'ABORTED'
                        return
                    }
                    env.CHANGED_SERVICES = changedServices.join(',')
                    echo "Detected changed services: ${env.CHANGED_SERVICES}"
                }
            }
        }

        stage('Build Changed Services') {
            parallel {
                stage('Build auth-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('auth-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'auth-service',
                            serviceType: 'spring-boot',
                            port: '8081',
                            hasTests: true
                        )
                    }
                }

                stage('Build api-gateway') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('api-gateway') }
                    }
                    steps {
                        buildService(
                            serviceName: 'api-gateway',
                            serviceType: 'spring-boot',
                            port: '8060',
                            hasTests: true
                        )
                    }
                }

                stage('Build plant-management-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('plant-management-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'plant-management-service',
                            serviceType: 'spring-boot',
                            port: '8085',
                            hasTests: true
                        )
                    }
                }

                stage('Build search-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('search-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'search-service',
                            serviceType: 'spring-boot',
                            port: '8088',
                            hasTests: true
                        )
                    }
                }

                stage('Build notification-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('notification-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'notification-service',
                            serviceType: 'spring-boot',
                            port: '8095',
                            hasTests: true
                        )
                    }
                }

                stage('Build socket-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('socket-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'socket-service',
                            serviceType: 'spring-boot',
                            port: '8093',
                            hasTests: true
                        )
                    }
                }

                stage('Build message-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('message-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'message-service',
                            serviceType: 'spring-boot',
                            port: '8092',
                            hasTests: true
                        )
                    }
                }

                stage('Build community-feed-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('community-feed-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'community-feed-service',
                            serviceType: 'spring-boot',
                            port: '8090',
                            hasTests: true
                        )
                    }
                }

                stage('Build profile-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('profile-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'profile-service',
                            serviceType: 'spring-boot',
                            port: '8086',
                            hasTests: true
                        )
                    }
                }

                stage('Build file-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('file-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'file-service',
                            serviceType: 'spring-boot',
                            port: '8084',
                            hasTests: true
                        )
                    }
                }

                stage('Build rag-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('rag-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'rag-service',
                            serviceType: 'python',
                            port: '8199',
                            hasTests: true,
                            gpuEnabled: false
                        )
                    }
                }

                stage('Build disease-detection-service') {
                    when {
                        expression { env.CHANGED_SERVICES.contains('disease-detection-service') }
                    }
                    steps {
                        buildService(
                            serviceName: 'disease-detection-service',
                            serviceType: 'python',
                            port: '8000',
                            hasTests: true,
                            gpuEnabled: false
                        )
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                // Cleanup workspace
                cleanWs deleteDirs: true, notFailBuild: true

                // Archive build artifacts
                archiveArtifacts artifacts: '**/target/*.jar,**/target/*.war,**/dist/**/*.whl', allowEmptyArchive: true, fingerprint: true

                // Publish test results
                junit '**/target/surefire-reports/*.xml', allowEmptyResults: true
                publishHTML([
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '**/target/site/jacoco',
                    reportFiles: 'index.html',
                    reportName: 'Coverage Report'
                ])
            }
        }

        success {
            script {
                if (env.GIT_BRANCH == 'main' || env.GIT_BRANCH.startsWith('release/')) {
                    slackSend(
                        channel: '#deployments',
                        color: 'good',
                        message: "✅ Build #${env.BUILD_NUMBER} succeeded for ${env.GIT_BRANCH} - ${env.CHANGED_SERVICES}"
                    )
                }
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#deployments',
                    color: 'danger',
                    message: "❌ Build #${env.BUILD_NUMBER} failed for ${env.GIT_BRANCH} - ${env.CHANGED_SERVICES}"
                )
            }
        }
    }
}

// Helper function to detect which services have changed
def detectChangedServices() {
    def changedFiles = []
    def services = []

    try {
        // Get the list of changed files from Git
        def output = sh(
            script: 'git diff --name-only HEAD~1 HEAD',
            returnStdout: true
        ).trim()

        if (output) {
            changedFiles = output.split('\\n')
        }
    } catch (Exception e) {
        echo "Could not get changed files: ${e.message}"
        // If we can't determine changes, build all
        return getAllServices()
    }

    // Map changed files to services
    def serviceMap = [
        'auth-service': 'backend/auth-service/',
        'api-gateway': 'backend/api-gateway/',
        'plant-management-service': 'backend/plant-management-service/',
        'search-service': 'backend/search-service/',
        'notification-service': 'backend/notification-service/',
        'socket-service': 'backend/socket-service/',
        'message-service': 'backend/message-service/',
        'community-feed-service': 'backend/community-feed-service/',
        'profile-service': 'backend/profile-service/',
        'file-service': 'backend/file-service/',
        'rag-service': 'backend/rag-service/',
        'disease-detection-service': 'backend/disease-detection-service/',
        'config-server': 'backend/config-server/',
        'discovery-server': 'backend/discovery-server/'
    ]

    for (file in changedFiles) {
        for (entry in serviceMap) {
            if (file.startsWith(entry.value)) {
                services.add(entry.key)
                break
            }
        }
    }

    return services.unique()
}

// Get all services
def getAllServices() {
    return [
        'auth-service', 'api-gateway', 'plant-management-service',
        'search-service', 'notification-service', 'socket-service',
        'message-service', 'community-feed-service', 'profile-service',
        'file-service', 'rag-service', 'disease-detection-service'
    ]
}

// Build a single service
def buildService(Map config) {
    def serviceName = config.serviceName
    def serviceType = config.serviceType ?: 'spring-boot'
    def port = config.port ?: '8080'
    def hasTests = config.hasTests ?: true
    def gpuEnabled = config.gpuEnabled ?: false

    def imageTag = "${env.GIT_COMMIT[0..7]}-${env.BUILD_NUMBER}"
    def dockerRegistry = env.DOCKER_REGISTRY ?: 'localhost:5000'

    pipeline {
        agent {
            docker {
                image serviceType == 'python' ? 'python:3.11-slim' : 'maven:3.9-eclipse-temurin-21-alpine'
            }
        }

        stages {
            stage('Build') {
                steps {
                    script {
                        if (serviceType == 'python') {
                            sh """
                                pip install -r backend/${serviceName}/requirements.txt --quiet || true
                            """
                        } else {
                            sh """
                                mvn -f backend/${serviceName}/pom.xml clean package -DskipTests -B
                            """
                        }
                    }
                }
            }

            stage('Test') {
                when { expression { hasTests } }
                steps {
                    script {
                        if (serviceType == 'python') {
                            sh "pytest backend/${serviceName}/tests/ -v || true"
                        } else {
                            sh "mvn -f backend/${serviceName}/pom.xml test -B || true"
                        }
                    }
                }
            }

            stage('Docker Build & Push') {
                steps {
                    script {
                        sh """
                            docker build \
                                -f backend/${serviceName}/Dockerfile \
                                -t ${dockerRegistry}/${serviceName}:${imageTag} \
                                -t ${dockerRegistry}/${serviceName}:${env.GIT_BRANCH} \
                                backend/
                        """

                        withCredentials([usernamePassword(
                            credentialsId: 'docker-registry',
                            usernameVariable: 'DOCKER_USER',
                            passwordVariable: 'DOCKER_PASS'
                        )]) {
                            sh """
                                docker login -u \$DOCKER_USER -p \$DOCKER_PASS ${dockerRegistry} || true
                                docker push ${dockerRegistry}/${serviceName}:${imageTag}
                                docker push ${dockerRegistry}/${serviceName}:${env.GIT_BRANCH} || true
                            """
                        }
                    }
                }
            }

            stage('Deploy to Staging') {
                when {
                    anyOf {
                        branch 'main'
                        branch 'develop'
                        branch pattern: 'release/.*', comparator: 'REGEXP'
                    }
                }
                steps {
                    script {
                        sh """
                            cd backend
                            # Update image in compose file
                            sed -i 's|image: ${dockerRegistry}/${serviceName}:.*|image: ${dockerRegistry}/${serviceName}:${imageTag}|g' docker-compose.yml
                            # Pull new image
                            docker pull ${dockerRegistry}/${serviceName}:${imageTag}
                            # Restart service
                            docker-compose up -d ${serviceName}
                            # Wait for health
                            sleep 30
                        """
                    }
                }
            }
        }
    }
}
